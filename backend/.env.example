# Database driver: "sqlite" or "postgres"
DB_DRIVER=sqlite

# SQLite: path to file
DB_DSN=shortly.db

# PostgreSQL: connection string
# DB_DSN=postgres://user:password@localhost:5432/shortly?sslmode=disable

# Server port
PORT=8080

# Public base URL (used for short links)
BASE_URL=http://localhost:8080
